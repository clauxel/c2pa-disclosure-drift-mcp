    "tokenClaimUrl": "https://c2padisclosure.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "starter",
        "name": "Starter",
        "monthlyUsd": 59
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 179
      },
      {
        "id": "compliance",
        "name": "Compliance",
        "monthlyUsd": 499
      }
    ]
  },
