{
  "name": "c2padisclosure",
  "title": "C2PA Disclosure Drift",
  "description": "A paid remote MCP for C2PA disclosure policy MCP, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://c2padisclosure.clauxel.com/",
  "documentationUrl": "https://c2padisclosure.clauxel.com/mcp/",
  "endpointUrl": "https://c2padisclosure.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://c2padisclosure.clauxel.com/api/agent-checkout",
